# ============================================================
# Memorise — environment configuration
# Copy this file to `.env` and fill in the values. `.env` is gitignored.
# ============================================================

# --- Clerk (authentication) ---
# Clerk Dashboard > API Keys > Publishable key (starts with pk_).
# In Clerk Dashboard > User & Authentication > Social Connections:
# enable ONLY Google, and disable email/password so the sign-in shows a
# single "Continue with Google" button.
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Google native sign-in (account picker) ---
# Lets tapping "Lanjut dengan Google" show the phone's existing Google accounts
# instead of a web login. Leave blank to fall back to Clerk's web OAuth flow.
# Setup:
#   1. Google Cloud Console > APIs & Services > Credentials > Create OAuth client ID:
#      - one "Web application" client  -> paste its client ID below (serverClientId)
#      - one "Android" client bound to the app's package name + signing SHA-1
#   2. Clerk Dashboard > Social Connections > Google > use custom credentials and
#      enable the native "Sign in with Google (One Tap)" / id-token strategy.
GOOGLE_SERVER_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxx.apps.googleusercontent.com

# --- Google Sheets (progress database) ---
# The ID of the (empty) spreadsheet, from its URL:
# https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
# IMPORTANT: share that spreadsheet (Editor) with the service account's
# client_email below. The app auto-creates the sheets/columns it needs.
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here

# Full service account JSON on ONE line, wrapped in single quotes.
# Google Cloud Console > IAM & Admin > Service Accounts > Keys > Add key (JSON).
# Keep the \n inside private_key exactly as Google gives it.
GOOGLE_SHEETS_CREDENTIALS='{"type":"service_account","project_id":"your-project","private_key_id":"xxxx","private_key":"-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n","client_email":"memorise-bot@your-project.iam.gserviceaccount.com","client_id":"1234567890","token_uri":"https://oauth2.googleapis.com/token"}'
